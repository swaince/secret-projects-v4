{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    },
    "shadcnVue": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "shadcn-vue@latest",
        "mcp"
      ]
    }
  },
  "lsp": true,
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"]
}
